{
  "/auth/*": "/auth/$1",
  "/api/v1/movies": "/movies",
  "/api/v1/movies/:id": "/movies/:id",
  "/api/v1/movies/now-showing": "/movies?status=Now Showing",
  "/api/v1/movies/coming-soon": "/movies?status=Coming Soon",
  "/api/v1/movies/search\\?name=:name": "/movies?title_like=:name",
  "/api/v1/branches": "/branches",
  "/api/v1/branches/:id": "/branches/:id",
  "/api/v1/branches/:branchId/rooms": "/rooms?branchId=:branchId",
  "/api/v1/branches/:branchId/rooms/:roomId": "/rooms?branchId=:branchId&id=:roomId",
  "/api/v1/showtimes": "/showtimes",
  "/api/v1/showtimes/:id": "/showtimes/:id",
  "/api/v1/showtimes/movie/:movieId": "/showtimes?movieId=:movieId",
  "/api/v1/food-drinks": "/food-drinks",
  "/api/v1/customers": "/customers",
  "/api/v1/orders": "/orders",
  "/api/v1/employees": "/employees",
  "/api/v1/employees/:id": "/employees/:id",
  "/api/v1/employees/branch/:branchId": "/employees?branchId=:branchId"
}